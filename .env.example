# Google Gemini API key used by the serverless chatbot (api/chat.ts).
# Get a free key at: https://aistudio.google.com/app/apikey
# Local dev: copy this file to .env.local and run `vercel dev`.
# Production: add GEMINI_API_KEY in Vercel → Project → Settings → Environment Variables.
GEMINI_API_KEY=your_gemini_api_key_here
